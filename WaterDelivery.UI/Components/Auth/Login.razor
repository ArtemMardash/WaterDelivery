@page "/login"

<PageTitle>Login</PageTitle>

<div class="login-container">
    <div class="login-card">
        <h1>Sign in</h1>
        <p class="subtitle">Continue with Google to access the application.</p>

        @* Plain anchor -> UI-owned OAuth endpoint on the same host, so no interactivity needed. *@
        <a class="google-btn" href="@LoginHref">
            <span class="google-icon">G</span>
            <span>Sign in with Google</span>
        </a>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private string LoginHref => string.IsNullOrWhiteSpace(ReturnUrl)
        ? "/auth/login"
        : $"/auth/login?returnUrl={Uri.EscapeDataString(ReturnUrl)}";
}
