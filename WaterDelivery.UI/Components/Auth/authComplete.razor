@page "/auth/complete"
@inject NavigationManager Navigation

<p>Signing you in…</p>

@code {
    // Sign-in is now completed by the UI OAuth callback (/auth/google-callback), which sets the
    // cookie directly. This page only remains so any older bookmarked link still lands somewhere sane.
    protected override void OnInitialized()
    {
        Navigation.NavigateTo("/proceed-to-checkout");
    }
}
