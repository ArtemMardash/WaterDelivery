@page "/proceed-to-checkout"
@using WaterDelivery.Contracts.Addresses.Dtos
@using WaterDelivery.Contracts.CustomersAddresses.Dtos
@using WaterDelivery.Contracts.Orders.Dtos
@using WaterDelivery.UI.Components.Auth
@using WaterDelivery.UI.Components.Cart
@inject NavigationManager Navigation
@inject CartService CartService
@inject IHttpClientFactory HttpClientFactory
@inject UserSession Session
@rendermode InteractiveServer

<PageTitle>Secure Checkout</PageTitle>

<div class="place-order-layout">
    <div class="place-order-container">

        <div class="place-order-header">
            <button class="back-btn" @onclick="GoBack">← Back to cart</button>
            <h1>Place Your Order</h1>
            <p>Choose where we should deliver, then confirm your order.</p>
        </div>

        <div class="order-body">

            <!-- Order Summary -->
            <div class="order-summary-card">
                <h2>Order Summary</h2>
                @if (CartService.Items.Count == 0)
                {
                    <p class="empty-cart-msg">Your cart is empty. <a href="/catalog">Go back to catalog.</a></p>
                }
                else
                {
                    <div class="summary-items">
                        @foreach (var item in CartService.Items)
                        {
                            <div class="summary-item">
                                <span class="summary-item-name">@item.Name</span>
                                <span class="summary-item-qty">x@item.Quantity</span>
                                <span class="summary-item-price">$@((item.Price * item.Quantity).ToString("0.00"))</span>
                            </div>
                        }
                    </div>
                    <div class="summary-total">
                        <span>Total</span>
                        <strong>$@CartService.Total.ToString("0.00")</strong>
                    </div>
                    <div class="payment-notice">
                        <span class="payment-badge">💵 Pay on delivery</span>
                    </div>
                }
            </div>

            <!-- Delivery Address -->
            <div class="address-card">
                <h2>Delivery Address</h2>

                @if (_loadingAddresses)
                {
                    <p class="empty-cart-msg">Loading your saved addresses…</p>
                }
                else
                {
                    @if (_savedAddresses.Count > 0)
                    {
                        <div class="address-list">
                            @foreach (var address in _savedAddresses)
                            {
                                <button type="button"
                                        class="address-option @(IsSelected(address) ? "address-option-selected" : "")"
                                        @onclick="() => SelectAddress(address)">
                                    <span class="address-option-radio">@(IsSelected(address) ? "●" : "○")</span>
                                    <span class="address-option-text">
                                        <strong>@address.Street @address.HouseNumber@(string.IsNullOrWhiteSpace(address.AptNumber) ? "" : $", {address.AptNumber}")</strong>
                                        <span>@address.City, @address.State</span>
                                    </span>
                                </button>
                            }

                            <button type="button"
                                    class="address-option @(_useNewAddress ? "address-option-selected" : "")"
                                    @onclick="UseNewAddress">
                                <span class="address-option-radio">@(_useNewAddress ? "●" : "○")</span>
                                <span class="address-option-text"><strong>Use a new address</strong></span>
                            </button>
                        </div>
                    }

                    @if (_useNewAddress || _savedAddresses.Count == 0)
                    {
                        <div class="form-grid">
                            <div class="form-group full-width">
                                <label>Street</label>
                                <input type="text" @bind="_street" placeholder="e.g. Main Street" class="form-input @(ShowError(_street) ? "input-error" : "")"/>
                                @if (ShowError(_street))
                                {
                                    <span class="field-error">Street is required</span>
                                }
                            </div>

                            <div class="form-group">
                                <label>House Number</label>
                                <input type="text" @bind="_houseNumber" placeholder="e.g. 42" class="form-input @(ShowError(_houseNumber) ? "input-error" : "")"/>
                                @if (ShowError(_houseNumber))
                                {
                                    <span class="field-error">House number is required</span>
                                }
                            </div>

                            <div class="form-group">
                                <label>Apartment / Unit <span class="optional">(optional)</span></label>
                                <input type="text" @bind="_aptNumber" placeholder="e.g. Apt 3B" class="form-input"/>
                            </div>

                            <div class="form-group">
                                <label>City</label>
                                <input type="text" @bind="_city" placeholder="e.g. New York" class="form-input @(ShowError(_city) ? "input-error" : "")"/>
                                @if (ShowError(_city))
                                {
                                    <span class="field-error">City is required</span>
                                }
                            </div>

                            <div class="form-group">
                                <label>State</label>
                                <input type="text" @bind="_state" placeholder="e.g. NY" class="form-input @(ShowError(_state) ? "input-error" : "")"/>
                                @if (ShowError(_state))
                                {
                                    <span class="field-error">State is required</span>
                                }
                            </div>
                        </div>
                    }
                }
            </div>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="error-banner">⚠ @_errorMessage</div>
            }

            <button class="btn-primary submit-btn" @onclick="SubmitOrder" disabled="@(_isSubmitting || CartService.Items.Count == 0)">
                @if (_isSubmitting)
                {
                    <span class="spinner"></span>
                    <span>Placing order...</span>
                }
                else
                {
                    <span>Confirm Order</span>
                }
            </button>

        </div>
    </div>
</div>

@code {
    private HttpClient _backendClient = default!;
    private Guid _customerId;
    private List<AddressDto> _savedAddresses = new();
    private AddressDto? _selectedAddress;
    private bool _useNewAddress;
    private bool _loadingAddresses = true;

    // New-address form fields
    private string _street = string.Empty;
    private string _houseNumber = string.Empty;
    private string _aptNumber = string.Empty;
    private string _city = string.Empty;
    private string _state = string.Empty;

    // UI state
    private bool _isSubmitting;
    private bool _submitted;
    private string _errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _backendClient = HttpClientFactory.CreateClient("backendClient");

        var userId = await Session.GetUserIdAsync();
        if (userId is null)
        {
            Navigation.NavigateTo("/login?returnUrl=/proceed-to-checkout", forceLoad: true);
            return;
        }

        _customerId = userId.Value;
        await LoadAddresses();
    }

    private async Task LoadAddresses()
    {
        _loadingAddresses = true;
        try
        {
            var response = await _backendClient.GetAsync($"/api/waterDelivery/customerAddress/{_customerId}");
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<GetCustomerAddressesResultDto>();
                _savedAddresses = result?.Addresses ?? new List<AddressDto>();
            }
            else
            {
                _savedAddresses = new List<AddressDto>();
            }
        }
        catch
        {
            _savedAddresses = new List<AddressDto>();
        }

        // Default selection: first saved address, otherwise the new-address form.
        if (_savedAddresses.Count > 0)
        {
            _selectedAddress = _savedAddresses[0];
            _useNewAddress = false;
        }
        else
        {
            _useNewAddress = true;
        }

        _loadingAddresses = false;
    }

    private bool IsSelected(AddressDto address) =>
        !_useNewAddress && _selectedAddress is not null && _selectedAddress.Id == address.Id;

    private void SelectAddress(AddressDto address)
    {
        _selectedAddress = address;
        _useNewAddress = false;
        _errorMessage = string.Empty;
    }

    private void UseNewAddress()
    {
        _useNewAddress = true;
        _selectedAddress = null;
        _errorMessage = string.Empty;
    }

    private bool ShowError(string value) => _submitted && _useNewAddress && string.IsNullOrWhiteSpace(value);

    private void GoBack() => Navigation.NavigateTo("/catalog");

    private async Task SubmitOrder()
    {
        _submitted = true;
        _errorMessage = string.Empty;

        if (CartService.Items.Count == 0)
        {
            _errorMessage = "Your cart is empty.";
            return;
        }

        AddressDto address;
        bool isNew;

        if (_useNewAddress || _savedAddresses.Count == 0)
        {
            if (string.IsNullOrWhiteSpace(_street) ||
                string.IsNullOrWhiteSpace(_houseNumber) ||
                string.IsNullOrWhiteSpace(_city) ||
                string.IsNullOrWhiteSpace(_state))
            {
                return; // field errors are shown inline
            }

            address = new AddressDto
            {
                Id = Guid.Empty,
                Street = _street,
                HouseNumber = _houseNumber,
                AptNumber = string.IsNullOrWhiteSpace(_aptNumber) ? null : _aptNumber,
                City = _city,
                State = _state
            };
            isNew = true;
        }
        else
        {
            if (_selectedAddress is null)
            {
                _errorMessage = "Please choose a delivery address.";
                return;
            }

            address = _selectedAddress;
            isNew = false;
        }

        _isSubmitting = true;

        try
        {
            var request = new PlaceOrderRequest
            {
                CustomerId = _customerId,
                Address = address,
                IsNewAddress = isNew,
                Items = CartService.Items.Select(item => new OrderItemDto
                {
                    Product = item.Product,
                    Quantity = item.Quantity,
                    ProductUnit = item.Product.DefaultUnit
                }).ToList()
            };

            var placeOrderUseCase = new PlaceOrderUseCase(_backendClient);
            var result = await placeOrderUseCase.ExecuteAsync(request, CancellationToken.None);

            // Hand the order to the status page; addressId lets that page build the delivery on payment.
            Navigation.NavigateTo($"/order-status/{result.BillId}?addressId={result.AddressId}");
        }
        catch (InvalidOperationException ex)
        {
            _errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            _errorMessage = $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
